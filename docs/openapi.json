{
  "components": {
    "schemas": {
      "HealthResponse": {
        "description": "HTTP response schema for health checks.\n\nAttributes:\n    service_id: Stable service identifier.\n    name: Service display name.\n    healthy: Whether the service is available.",
        "properties": {
          "healthy": {
            "title": "Healthy",
            "type": "boolean"
          },
          "name": {
            "title": "Name",
            "type": "string"
          },
          "service_id": {
            "format": "uuid",
            "title": "Service Id",
            "type": "string"
          }
        },
        "required": [
          "service_id",
          "name",
          "healthy"
        ],
        "title": "HealthResponse",
        "type": "object"
      }
    }
  },
  "info": {
    "title": "utl-template",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/health": {
      "get": {
        "description": "Return service health.\n\nArgs:\n    use_case: Health check use case.\n\nReturns:\n    HTTP health response.\n\nRaises:\n    DomainError: If health status cannot be represented.",
        "operationId": "get_health_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Get Health",
        "tags": [
          "health"
        ]
      }
    }
  }
}
