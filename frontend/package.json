{
  "name": "utl-template-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev": "vite --config src/config/vite.config.ts",
    "build": "tsc --noEmit && vite build --config src/config/vite.config.ts",
    "preview": "vite preview --config src/config/vite.config.ts",
    "biome": "biome check --config-path biome.json .",
    "generate:api": "openapi-typescript ../docs/openapi.json -o src/api/generated/schema.ts",
    "knip": "knip --config src/config/knip.json",
    "test": "vitest run --config src/config/vite.config.ts --coverage",
    "e2e": "playwright test --config src/config/playwright.config.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "vite": "^8.0.13",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.6",
    "jsdom": "^29.1.1",
    "knip": "^6.14.1",
    "openapi-typescript": "^7.13.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
